core/target
*.a
*.so
sy/

# 批次 APK 构建产物：占用磁盘大（每个 ~144MB），不入版本库
# 用户在本地按需 build，不上传仓库
dist/
flutter_app/build
flutter_app/.dart_tool

# Android jniLibs：build 产物，不入版本库
# 由 cargo build --release --target aarch64-linux-android 生成，
# 再由 build_android_*.sh 脚本拷贝过来；现有 *.so 全局规则对已 tracked
# 文件无效，因此显式加目录级规则做防御。
flutter_app/android/app/src/main/jniLibs/

# Trellis: per-developer workspace (journals, session traces)
.trellis/workspace/

# Android release signing：本地 keystore + properties 不入版本库
flutter_app/android/key.properties
flutter_app/android/*.keystore
flutter_app/android/*.jks

